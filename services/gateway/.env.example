# API Gateway 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 基础配置
# ============================================
GATEWAY_PORT=8000
DEBUG=false

# ============================================
# SSO OIDC 配置
# ============================================
# OIDC 发现端点（必须配置）
OIDC_DISCOVERY_URL=http://192.168.192.189:38082/admin-api/system/oidc/.well-known/openid-configuration

# OIDC 客户端 ID（必须配置）
OIDC_CLIENT_ID=kbase

# OIDC 回调地址（必须配置，需要与 OIDC 服务器注册的一致）
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# 是否启用 SSO
SSO_ENABLED=true

# 前端登录页面地址（用于回调重定向）
SSO_FRONTEND_URL=http://localhost:3000/login

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=jusure-microservices-secret-key-2026
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=24

# ============================================
# Redis 配置（用于限流）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# 微服务地址配置
# ============================================
KNOWLEDGE_SERVICE_URL=http://localhost:7101
RAG_SERVICE_URL=http://localhost:7102
FILE_SERVICE_URL=http://localhost:7103
MODEL_SERVICE_URL=http://localhost:7104
CHAT_SERVICE_URL=http://localhost:7105
TASK_EXECUTOR_URL=http://localhost:7106
MEDIA_SERVICE_URL=http://localhost:7107
PROCESS_SERVICE_URL=http://localhost:7108
GRAPH_SERVICE_URL=http://localhost:7109
PARSER_SERVICE_URL=http://localhost:7110
SYSTEM_SERVICE_URL=http://localhost:7111
TABULATION_SERVICE_URL=http://localhost:7114
