# ============================================================
# Galaxy RAG 微服务环境变量配置
# ============================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际需求修改配置值
# 3. 敏感信息不要提交到版本控制系统
# ============================================================

# ==================== 基础配置 ====================
# 运行环境：local, development, staging, production
ENVIRONMENT=production

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=galaxy_rag
MYSQL_USER=galaxy_rag
MYSQL_PASSWORD=galaxy_rag123
MYSQL_PORT=3306

# ==================== MongoDB 配置 ====================
MONGO_USER=galaxy_rag
MONGO_PASSWORD=galaxy_rag123
MONGO_DATABASE=galaxy_rag
MONGO_PORT=27017

# ==================== Redis 配置 ====================
REDIS_PASSWORD=galaxy_rag123
REDIS_PORT=6379

# ==================== MinIO 配置 ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==================== Elasticsearch 配置 ====================
ES_PASSWORD=elastic123
ES_PORT=9200

# ==================== LLM API 配置 ====================
# OpenAI
LLM_API_KEY=sk-your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-4

# 或使用其他提供商（取消注释并配置）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-api-key
# DEFAULT_LLM_MODEL=qwen-plus

# 本地 Ollama（取消注释并配置）
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# DEFAULT_LLM_MODEL=qwen2.5:7b

# ==================== 文档解析器配置 ====================
# 是否启用 Ragflow 模式（融合 Ragflow 的解析逻辑）
PARSER_RAGFLOW_MODE=false

# PDF 解析策略（仅在 PARSER_RAGFLOW_MODE=true 时有效）
# false: 使用 jusure_AI 三库联合方案（fitz+pdfplumber+pdfminer）
# true: 使用 ragflow PlainParser（基于 fitz，轻量但无表格识别）
PARSER_RAGFLOW_PDF_PLAIN=false

# 分块配置
PARSER_CHUNK_TOKEN_NUM=512
PARSER_OVERLAP_PERCENT=0

# SaT 神经网络分句配置
PARSER_USE_SAT=true
PARSER_SAT_MODEL=sat-3l-sm

# 语义分块配置
PARSER_SEMANTIC_CHUNKING=false
PARSER_SEMANTIC_THRESHOLD=0.5
PARSER_SEMANTIC_BREAKPOINT_TYPE=percentile

# ==================== 服务地址配置 ====================
KNOWLEDGE_SERVICE_URL=http://knowledge-service:7101
RAG_SERVICE_URL=http://rag-service:7102
AGENT_SERVICE_URL=http://agent-service:7103
PARSER_SERVICE_URL=http://parser-service:7110

# ==================== 可选配置 ====================
# 调试模式（开发环境启用）
DEBUG=false

# 服务 Worker 数量
SERVICE_WORKERS=4

# 向量存储类型：elasticsearch, milvus, chromadb
VECTOR_STORE_TYPE=elasticsearch

# 嵌入维度（根据使用的 embedding 模型调整）
EMBEDDING_DIMS=1024

# 任务执行器配置
MAX_CONCURRENT_TASKS=5
MAX_CONCURRENT_CHUNKS=10
EMBEDDING_BATCH_SIZE=32
TASK_TIMEOUT=3600
