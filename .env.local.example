# 本地开发环境：Python 服务直接跑在本机，存储组件用本机 Docker 暴露端口。
ENVIRONMENT=local
DEBUG=true
NACOS_ENABLED=false
SERVICE_WORKERS=1

# MySQL（docker compose 暴露到 localhost:3307）
MYSQL_ROOT_PASSWORD=root123
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=galaxy_rag
MYSQL_USER=galaxy_rag
MYSQL_PASSWORD=galaxy_rag123
MYSQL_MAX_CONNECTIONS=50
MYSQL_POOL_SIZE=5

# Redis（docker compose 暴露到 localhost:6379）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=galaxy_rag123
REDIS_DB=0

# MinIO（docker compose 暴露到 localhost:9000/9001）
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jusure
MINIO_CONSOLE_PORT=9001
MINIO_SECURE=false

# Elasticsearch（docker compose 暴露到 localhost:9200）
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USER=
ES_PASSWORD=
VECTOR_STORE_TYPE=elasticsearch
VECTOR_INDEX_PREFIX=jusure
EMBEDDING_DIMS=1024

# MongoDB 当前精简版不启动、不依赖；保留空配置避免旧代码读取时报错。
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=galaxy_rag

# LLM/Embedding：需要真实问答或向量化时再配置。
LLM_API_KEY=sk-ad0eca1e43bc60f825372c496f131e53
LLM_BASE_URL=http://114.242.210.44:8000/v1
DEFAULT_LLM_FACTORY=openai
DEFAULT_LLM_MODEL=jusure-llm
DEFAULT_EMBEDDING_MODEL=bge-m3

# 服务间地址（本地端口）
KNOWLEDGE_SERVICE_URL=http://localhost:7101
PARSER_SERVICE_URL=http://localhost:7106
RAG_SERVICE_URL=http://localhost:7102
AGENT_SERVICE_URL=http://localhost:7103

# 文档解析配置
PARSER_RAGFLOW_MODE=false
PARSER_CHUNK_TOKEN_NUM=512
PARSER_OVERLAP_PERCENT=0
PARSER_USE_SAT=false
PARSER_SEMANTIC_CHUNKING=false

# false: 使用外部 OIDC；true: 使用本地模拟登录
LOCAL_SSO_ENABLED=false

# 默认大模型/向量模型（OpenAI 兼容）
DEFAULT_LLM_BASE_URL=http://114.242.210.44:8000/v1
DEFAULT_LLM_MODEL_NAME=jusure-llm
DEFAULT_LLM_API_KEY=sk-ad0eca1e43bc60f825372c496f131e53
DEFAULT_EMBEDDING_BASE_URL=http://114.242.210.44:6300/v1/embeddings
DEFAULT_EMBEDDING_MODEL_NAME=qwen3-embed-4b
DEFAULT_EMBEDDING_API_KEY=sk-ad0eca1e43bc60f825372c496f131e53
